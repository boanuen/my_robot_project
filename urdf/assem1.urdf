<?xml version="1.0" encoding="utf-8"?>
<robot name="assem1">
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0.05 0.0 -0.02" rpy="0 0 0" /> 
      <mass value="4.0" />
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://assem1/meshes/base_link.STL" /></geometry>
    </visual>
    <collision>
      <geometry><box size="0.3 0.2 0.1" /></geometry>
    </collision>
  </link>

  <link name="left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" /> <mass value="0.4" />
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://assem1/meshes/left_wheel.STL" /></geometry>
    </visual>
    <collision>
      <geometry><cylinder radius="0.035" length="0.025" /></geometry>
    </collision>
  </link>

  <link name="right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" /> <mass value="0.4" />
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://assem1/meshes/right_wheel.STL" /></geometry>
    </visual>
    <collision>
      <geometry><cylinder radius="0.035" length="0.025" /></geometry>
    </collision>
  </link>

  <link name="armlink1">
    <inertial>
      <origin xyz="0 0 0.08" rpy="0 0 0" /> <mass value="0.8" />
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://assem1/meshes/armlink1.STL" /></geometry>
    </visual>
  </link>

  <link name="armlink2">
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0" /> <mass value="0.5" />
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://assem1/meshes/armlink2.STL" /></geometry>
    </visual>
  </link>

  <link name="caster_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" /> <mass value="0.1" />
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001" />
    </inertial>
    <visual>
      <geometry><sphere radius="0.02"/></geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.02"/></geometry>
    </collision>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <origin xyz="0.069 -0.036 -0.033" rpy="0 0 0" />
    <parent link="base_link" /><child link="left_wheel" /><axis xyz="1 0 0" />
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <origin xyz="-0.070 -0.036 -0.033" rpy="0 0 0" />
    <parent link="base_link" /><child link="right_wheel" /><axis xyz="1 0 0" />
  </joint>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0.12 0 -0.048" rpy="0 0 0"/>
  </joint>

  <joint name="armlink1_joint" type="revolute">
    <origin xyz="-0.002 0.001 0.173" rpy="-0.74 0 0.03" />
    <parent link="base_link" /><child link="armlink1" /><axis xyz="1 0 0" />
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1" />
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <joint name="armlink2_joint" type="revolute">
    <origin xyz="0.001 0.054 0.072" rpy="-1.29 0 0" />
    <parent link="armlink1" /><child link="armlink2" /><axis xyz="1 0 0" />
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1" />
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.14</wheel_separation>
      <wheel_radius>0.035</wheel_radius>
      <topic>cmd_vel</topic>
    </plugin>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>
  </gazebo>
</robot>